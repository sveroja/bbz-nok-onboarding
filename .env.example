# Kopiere diese Datei zu .env und passe die Werte an.
# Die .env selbst gehört NICHT ins Git!

# Flask-Modus: development oder production
FLASK_ENV=development

# Geheim, mindestens 32 zufällige Zeichen.
# Generieren z.B. mit:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=bitte-aendern-mindestens-32-zeichen-zufaellig

# Initiale Passwörter für die Standardnutzer (nur beim init-db genutzt)
ADMIN_PASSWORD=bitte-admin-passwort-setzen
TEACHER_PASSWORD=bitte-lehrer-passwort-setzen

# OpenPLZ-Referenz (PLZ der Schule)
REFERENCE_PLZ=24768

# Session-Cookie nur über HTTPS senden (in Produktion: True)
SESSION_COOKIE_SECURE=False
